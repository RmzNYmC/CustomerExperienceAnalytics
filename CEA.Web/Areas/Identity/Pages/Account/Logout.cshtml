@page
@model LogoutModel
@{
    ViewData["Title"] = "Çıkış Yapıldı";
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
}

<div class="text-center">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
    </div>
    
    <h2 class="fw-bold text-gray-800 mb-3">@ViewData["Title"]</h2>
    
    <p class="text-gray-600 mb-4">
        Uygulamadan başarıyla çıkış yaptınız.
    </p>
    
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        <span id="countdown">10</span> saniye içinde giriş sayfasına yönlendirileceksiniz...
    </div>
    
    <div class="mt-4">
        <a asp-page="/Account/Login" asp-area="Identity" class="btn btn-primary">
            <i class="bi bi-box-arrow-in-right me-2"></i>Hemen Giriş Yap
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // 10 saniye geri sayım ve yönlendirme
        let seconds = 10;
        const countdownElement = document.getElementById('countdown');
        const loginUrl = '/Identity/Account/Login';
        
        const timer = setInterval(function() {
            seconds--;
            countdownElement.textContent = seconds;
            
            if (seconds <= 0) {
                clearInterval(timer);
                window.location.href = loginUrl;
            }
        }, 1000);
        
        // Kullanıcı sayfadan ayrılmak isterse timer'ı temizle (opsiyonel)
        window.addEventListener('beforeunload', function() {
            clearInterval(timer);
        });
    </script>
}