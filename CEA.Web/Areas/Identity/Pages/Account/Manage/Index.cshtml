@page
@model IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Profil Yönetimi";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "/Pages/Shared/_Layout.cshtml"; // Ana layout'u kullan (sidebar'lı)
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-white"><i class="fas fa-user-cog me-2"></i>Profil Yönetimi</h3>
        <a href="/Admin/Dashboard" class="btn btn-outline-light btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Dashboard'a Dön
        </a>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="row">
        <!-- Sol Kolon: Profil Bilgileri -->
        <div class="col-lg-8 mb-4">
            <div class="card bg-white/10 backdrop-blur-md border-0 shadow-lg">
                <div class="card-header bg-white/20 border-0 py-3">
                    <h5 class="mb-0 text-white"><i class="fas fa-id-card me-2"></i>Kullanıcı Bilgileri</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="UpdateProfile">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-white/80">Kullanıcı Adı</label>
                                <input type="text" class="form-control bg-white/20 border-0 text-white" value="@Model.Username" readonly />
                                <small class="text-white/50">Değiştirilemez</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white/80">E-posta</label>
                                <input type="email" class="form-control bg-white/20 border-0 text-white" value="@Model.Email" readonly />
                                <small class="text-white/50">Değiştirilemez</small>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-white/80">Hesap Durumu</label>
                                <div>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success px-3 py-2"><i class="fas fa-check-circle me-1"></i>Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2"><i class="fas fa-times-circle me-1"></i>Pasif</span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-white/80">Kayıt Tarihi</label>
                                <input type="text" class="form-control bg-white/20 border-0 text-white"
                                       value="@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")" readonly />
                            </div>
                        </div>

                        <hr class="border-white/20 my-4" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ProfileInput.FirstName" class="form-label text-white"></label>
                                <input asp-for="ProfileInput.FirstName" class="form-control bg-white/90 border-0" />
                                <span asp-validation-for="ProfileInput.FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ProfileInput.LastName" class="form-label text-white"></label>
                                <input asp-for="ProfileInput.LastName" class="form-control bg-white/90 border-0" />
                                <span asp-validation-for="ProfileInput.LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ProfileInput.Department" class="form-label text-white"></label>
                                <input asp-for="ProfileInput.Department" class="form-control bg-white/90 border-0" />
                                <span asp-validation-for="ProfileInput.Department" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ProfileInput.PhoneNumber" class="form-label text-white"></label>
                                <input asp-for="ProfileInput.PhoneNumber" class="form-control bg-white/90 border-0" placeholder="555 123 4567" />
                                <span asp-validation-for="ProfileInput.PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save me-2"></i>Profili Güncelle
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sağ Kolon: Şifre Değiştirme -->
        <div class="col-lg-4">
            <div class="card bg-white/10 backdrop-blur-md border-0 shadow-lg">
                <div class="card-header bg-warning/20 border-0 py-3">
                    <h5 class="mb-0 text-white"><i class="fas fa-key me-2"></i>Şifre Değiştir</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="ChangePassword">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="PasswordInput.CurrentPassword" class="form-label text-white"></label>
                            <input asp-for="PasswordInput.CurrentPassword" class="form-control bg-white/90 border-0" />
                            <span asp-validation-for="PasswordInput.CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordInput.NewPassword" class="form-label text-white"></label>
                            <input asp-for="PasswordInput.NewPassword" class="form-control bg-white/90 border-0" />
                            <span asp-validation-for="PasswordInput.NewPassword" class="text-danger"></span>
                            <small class="text-white/50">En az 8 karakter</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordInput.ConfirmPassword" class="form-label text-white"></label>
                            <input asp-for="PasswordInput.ConfirmPassword" class="form-control bg-white/90 border-0" />
                            <span asp-validation-for="PasswordInput.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-warning text-dark fw-bold">
                                <i class="fas fa-lock me-2"></i>Şifreyi Değiştir
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Güvenlik İpuçları -->
            <div class="card bg-info/10 backdrop-blur-md border-0 shadow-lg mt-3">
                <div class="card-body p-3">
                    <h6 class="text-info mb-2"><i class="fas fa-shield-alt me-2"></i>Güvenlik İpuçları</h6>
                    <ul class="list-unstyled text-black/80 small mb-0">
                        <li><i class="fas fa-check text-info me-1"></i> En az 8 karakter kullanın</li>
                        <li><i class="fas fa-check text-info me-1"></i> Büyük/küçük harf ekleyin</li>
                        <li><i class="fas fa-check text-info me-1"></i> Sayı ve sembol kullanın</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}