@page "{token?}"
@model CEA.Web.Pages.Survey.ThankYouModel
@{
    ViewData["Title"] = "Teşekkürler";
    Layout = "_PublicLayout"; // ✅ Public layout kullan
}

<div class="text-center py-5">
    <div class="thank-you-icon">
        <i class="fas fa-check-circle"></i>
    </div>
    <h2 class="text-white">Teşekkür Ederiz!</h2>
    <p class="lead text-white/70">Anketi tamamladığınız için teşekkür ederiz.</p>
    
    <div class="alert alert-info bg-white/10 border-white/20 mt-4 mx-auto" style="max-width: 500px;">
        <i class="fas fa-info-circle me-2"></i>
        <span>Bu anketi zaten tamamladınız. Tekrar yanıt veremezsiniz.</span>
    </div>

    <a href="/" class="btn btn-glass-primary mt-4">
        <i class="fas fa-home me-2"></i>Ana Sayfaya Dön
    </a>
</div>