@page
@model CEA.Web.Pages.Survey.IndexModel
@using CEA.Core.Enums
@{
    ViewData["Title"] = Model.Survey?.Title ?? "Anket";
    Layout = "_PublicLayout"; // ✅ Admin layout yerine public layout kullan
}

<div class="container mt-5 mb-5">
    @if (!Model.ShowForm && !string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="card bg-success/20 border-success">
                    <div class="card-body py-5">
                        <i class="fas fa-check-circle fa-5x text-success mb-4"></i>
                        <h2 class="text-white">@Model.SuccessMessage</h2>
                        <p class="text-white/70 mt-3">Görüşleriniz bizim için çok değerlidir.</p>
                        <a href="/" class="btn btn-glass-primary mt-3">Ana Sayfaya Dön</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Survey == null)
    {
        <div class="alert alert-danger text-center">
            <h4>Anket bulunamadı veya süresi dolmuş.</h4>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-card">
                    <div class="card-header bg-transparent border-bottom border-white/10 py-4">
                        <h3 class="mb-0 text-white">@Model.Survey.Title</h3>
                        @if (!string.IsNullOrEmpty(Model.Survey.Description))
                        {
                            <p class="mb-0 mt-2 text-white/70">@Model.Survey.Description</p>
                        }
                    </div>
                    
                    <div class="card-body p-4">
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">@Model.ErrorMessage</div>
                        }

                        <form method="post">
                            <input type="hidden" asp-for="Token" />
                            
                            <div class="row g-3 mb-4 p-3 bg-white/5 rounded border border-white/10">
                                <h5 class="mb-3 text-white"><i class="fas fa-user me-2"></i>İletişim Bilgileri</h5>
                                <div class="col-md-6">
                                    <label class="form-label text-white">Ad Soyad <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control bg-white/10 border-white/20 text-white"
                                           asp-for="Response.CustomerName" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-white">E-posta <span class="text-danger">*</span></label>
                                        <input type="email" class="form-control bg-white/10 border-white/20 text-white"
                                               asp-for="Response.CustomerEmail" required>
                                            <small class="text-white/50">Aynı e-posta ile tekrar yanıt veremezsiniz.</small>
                                        </div>
                                    </div>

                                    <hr class="border-white/10 my-4">

                                    <h5 class="mb-4 text-white"><i class="fas fa-clipboard-list me-2"></i>Anket Soruları</h5>
                            
                                    @for (int i = 0; i < Model.Questions.Count; i++)
                                    {
                                        var question = Model.Questions[i];
                                        <div class="mb-4 p-3 border border-white/10 rounded bg-white/5">
                                            <h6 class="fw-bold mb-3 text-white">
                                                @(i + 1). @question.Text
                                                @if (question.IsRequired)
                                                {
                                                    <span class="text-danger">*</span>
                                                }
                                            </h6>

                                            @if (question.QuestionType == QuestionType.TextOpen)
                                            {
                                                <textarea class="form-control bg-white/10 border-white/20 text-white"
                                                          name="Answers[@i].Value" rows="3"></textarea>
                                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
                                            }
                                            else if (question.QuestionType == QuestionType.RatingScale)
                                            {
                                                <div class="d-flex gap-2 justify-content-center">
                                                    @for (int r = question.MinRating ?? 1; r <= (question.MaxRating ?? 5); r++)
                                                    {
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input" type="radio"
                                                                   name="Answers[@i].RatingValue"
                                                                   value="@r"
                                                                   id="q@(question.Id)_r@(r)">
                                                            <label class="form-check-label text-white" for="q@(question.Id)_r@(r)">@r</label>
                                                        </div>
                                                    }
                                                </div>
                                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
                                                <input type="hidden" name="Answers[@i].Value" value="" />
                                            }
                                            else if (question.QuestionType == QuestionType.NpsScore)
                                            {
                                                <div class="d-flex gap-1 justify-content-center flex-wrap">
                                                    @for (int r = 0; r <= 10; r++)
                                                    {
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input" type="radio"
                                                                   name="Answers[@i].RatingValue"
                                                                   value="@r"
                                                                   id="q@(question.Id)_nps@(r)">
                                                            <label class="form-check-label text-white" for="q@(question.Id)_nps@(r)">@r</label>
                                                        </div>
                                                    }
                                                </div>
                                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
                                                <input type="hidden" name="Answers[@i].Value" value="" />
                                            }
                                            else if (question.QuestionType == QuestionType.SingleChoice)
                                            {
                                                @foreach (var option in question.Options.Where(o => !o.IsDeleted).OrderBy(o => o.DisplayOrder))
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio"
                                                               name="Answers[@i].Value"
                                                               value="@option.Text"
                                                               id="opt_@option.Id">
                                                        <label class="form-check-label text-white" for="opt_@option.Id">@option.Text</label>
                                                    </div>
                                                }
                                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
                                            }
                                            else if (question.QuestionType == QuestionType.MultipleChoice)
                                            {
                                                @foreach (var option in question.Options.Where(o => !o.IsDeleted).OrderBy(o => o.DisplayOrder))
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox"
                                                               name="Answers[@i].Value"
                                                               value="@option.Text"
                                                               id="opt_@option.Id">
                                                        <label class="form-check-label text-white" for="opt_@option.Id">@option.Text</label>
                                                    </div>
                                                }
                                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
                                            }
                                        </div>
                                    }

                                    <div class="d-grid gap-2 mt-4">
                                        <button type="submit" class="btn btn-glass-success btn-lg">
                                            <i class="fas fa-paper-plane me-2"></i>Anketi Gönder
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @section Scripts {
            <partial name="_ValidationScriptsPartial" />
        }