@page
@model CEA.Web.Pages.Survey.IndexModel
@using CEA.Core.Enum
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = Model.Survey?.Title ?? "Anket";
}

<div class="survey-page">
    <div class="survey-container">
        
        <!-- İlerleme Çubuğu -->
        <div class="progress-container">
            <div class="progress-bar" id="progressBar" style="width: 0%"></div>
        </div>

        <!-- Başlık -->
        <div class="survey-header">
            <h1 class="survey-title">@Model.Survey?.Title</h1>
            <p class="survey-description">@Model.Survey?.Description</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form method="post" id="surveyForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <!-- İletişim Bilgileri Kartı -->
            <div class="survey-card">
                <h3 class="card-title">
                    <i class="fas fa-user-circle"></i>
                    İletişim Bilgileri
                </h3>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">
                            Ad Soyad <span class="required">*</span>
                        </label>
                        <input asp-for="SurveyResponse.CustomerName"
                               class="form-control-modern"
                               placeholder="Adınız ve soyadınız"
                               required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">
                            E-posta <span class="required">*</span>
                        </label>
                        <input asp-for="SurveyResponse.CustomerEmail"
                               type="email"
                               class="form-control-modern"
                               placeholder="ornek@email.com"
                               required />
                        <small class="text-muted d-block mt-1">
                            <i class="fas fa-info-circle"></i>
                            Aynı e-posta ile tekrar yanıt veremezsiniz.
                        </small>
                    </div>
                </div>
            </div>

            <!-- Anket Soruları -->
            <div class="survey-card">
                <h3 class="card-title">
                    <i class="fas fa-clipboard-list"></i>
                    Anket Soruları
                </h3>

                @{
                    int answerIndex = 0;
                }

                @foreach (var question in Model.Questions)
                {
                    <div class="question-item mb-4" data-question-id="@question.Id">
                        <label class="form-label">
                            @question.DisplayOrder. @question.Text
                            @if (question.IsRequired)
                            {
                                <span class="required">*</span>
                            }
                        </label>

                        <!-- QuestionId için hidden field (HER SORU TİPİ İÇİN) -->
                        <input type="hidden" name="Answers[@answerIndex].QuestionId" value="@question.Id" />

                        @switch (question.QuestionType)
                        {
                            case QuestionType.NpsScore:
                            case QuestionType.RatingScale:
                                <div class="rating-container">
                                    @for (int i = 0; i <= 10; i++)
                                    {
                                        <div class="rating-item">
                                            <input type="radio"
                                                   name="Answers[@answerIndex].RatingValue"
                                                   value="@i"
                                                   id="rating_@(question.Id)_@i"
                                                   class="rating-input"
                                                   data-trigger="@question.TriggerComplaintOnLowRating"
                                                   data-threshold="@question.ComplaintThreshold"
                                                   onchange="checkRating(this, @question.Id)"
                                                   required="@question.IsRequired" />
                                            <label for="rating_@(question.Id)_@i" class="rating-label">
                                                @i
                                            </label>
                                        </div>
                                    }
                                </div>
                                
                                <!-- Düşük Puan Uyarısı -->
                                @if (question.TriggerComplaintOnLowRating)
                                {
                                    <div class="low-rating-warning" id="warning_@question.Id">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        <strong>Düşük memnuniyet algılandı.</strong><br>
                                        Görüşleriniz şikayet olarak kaydedilecektir.
                                    </div>
                                }
                                break;

                            case QuestionType.MultipleChoice:
                                <div class="options-container">
                                    @{
                                        int optionIndex = 0;
                                    }
                                    @foreach (var option in question.Options)
                                    {
                                        <input type="hidden" name="Answers[@answerIndex].QuestionId" value="@question.Id" />
                                        <label class="checkbox-modern">
                                            <input type="checkbox"
                                                   name="Answers[@answerIndex].Value"
                                                   value="@option.Text"
                                                   id="option_@(question.Id)_@optionIndex"
                                                   onchange="updateProgress()" />
                                            <span>@option.Text</span>
                                        </label>
                                        answerIndex++;
                                        optionIndex++;
                                    }
                                </div>
                                if (!question.Options.Any())
                                {
                                    <input type="hidden" name="Answers[@answerIndex].QuestionId" value="@question.Id" />
                                    answerIndex++;
                                }
                                break;

                            case QuestionType.TextOpen:
                                <textarea name="Answers[@answerIndex].Value"
                                          class="textarea-modern"
                                          placeholder="Görüş ve önerilerinizi yazın..."
                                          oninput="updateProgress()"
                                          rows="4"></textarea>
                                break;
                        }
                    </div>
                    
                    answerIndex++;
                }
            </div>

            <!-- Gönder Butonu -->
            <button type="submit" class="submit-btn">
                <i class="fas fa-paper-plane"></i>
                Anketi Gönder
                <i class="fas fa-arrow-right"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // İlerleme Çubuğu Güncelleme
        function updateProgress() {
            const form = document.getElementById('surveyForm');
            const totalQuestions = form.querySelectorAll('[data-question-id]').length;
            const answeredQuestions = form.querySelectorAll('input[type="radio"]:checked, input[type="checkbox"]:checked, textarea:not(:empty)').length;
            const progress = (answeredQuestions / totalQuestions) * 100;
            document.getElementById('progressBar').style.width = progress + '%';
        }

        // Düşük Puan Kontrolü
        function checkRating(radio, questionId) {
            const value = parseInt(radio.value);
            const threshold = parseInt(radio.dataset.threshold);
            const warning = document.getElementById('warning_' + questionId);
            
            if (warning && value <= threshold) {
                warning.classList.add('show');
            } else if (warning) {
                warning.classList.remove('show');
            }
            
            updateProgress();
        }

        // Form Submit Öncesi Kontrol
        document.getElementById('surveyForm').addEventListener('submit', function(e) {
            const requiredRadios = document.querySelectorAll('input[type="radio"][required]');
            const questionGroups = {};
            
            requiredRadios.forEach(radio => {
                const name = radio.name;
                if (!questionGroups[name]) {
                    questionGroups[name] = false;
                }
                if (radio.checked) {
                    questionGroups[name] = true;
                }
            });
            
            for (const [name, isChecked] of Object.entries(questionGroups)) {
                if (!isChecked) {
                    e.preventDefault();
                    alert('Lütfen tüm zorunlu soruları yanıtlayın.');
                    return false;
                }
            }
        });

        // Sayfa Yüklendiğinde
        document.addEventListener('DOMContentLoaded', function() {
            updateProgress();
        });
    </script>
}