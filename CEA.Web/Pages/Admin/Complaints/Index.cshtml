@page
@model CEA.Web.Pages.Admin.Complaints.IndexModel
@{
    ViewData["Title"] = "Şikayet Yönetimi";
}

<div @* class="container-fluid" *@>
    <!-- Başlık ve Butonlar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="text-white fw-bold">
                <i class="fas fa-clipboard-list me-2 text-blue-300"></i>Şikayet Yönetimi
            </h4>
            <p class="text-muted-gray mt-1">Müşteri şikayetlerini yönetin, atayın ve takip edin</p>
        </div>
        <form method="post" asp-page-handler="CheckSla" class="d-inline">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-clock me-2"></i>SLA Kontrolü
            </button>
        </form>
    </div>

    <!-- Özet Kartları -->
    <div class="row mb-4">
        <!-- Toplam Şikayet -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Toplam</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.SlaMetrics.TotalComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clipboard-list fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Açık Şikayetler -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Açık</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @(Model.Complaints.Count(c => c.Status != "Closed" && c.Status != "Resolved"))
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SLA Aşımı -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">SLA Aşımı</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.SlaMetrics.BreachedCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SLA Uyum Oranı -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">SLA Uyum</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @Model.SlaMetrics.SlaComplianceRate.ToString("F0")%
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ort. Çözüm Süresi -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Ort. Çözüm</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @(Model.SlaMetrics.AverageResolutionTimeMinutes > 0 
                                    ? $"{(Model.SlaMetrics.AverageResolutionTimeMinutes / 60):F1}s" 
                                    : "-")
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-stopwatch fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Kritik Şikayetler -->
        <div class="col-xl-2 col-md-4 mb-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-dark text-uppercase mb-1">Kritik</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                @Model.Complaints.Count(c => c.Priority == "Critical")
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-fire fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sol: Filtreler ve Liste -->
        <div class="col-lg-9 ">
            <!-- Filtreler Card -->
            <div class="glass-card p-3 mb-4 " style="background: rgba(30, 58, 138, 0.4) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="m-0 font-weight-bold text-white">
                        <i class="fas fa-filter me-2"></i>Filtreler
                    </h6>
                    <a href="./" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-undo me-1"></i>Sıfırla
                    </a>
                </div>
    
                <form method="get">
                    <div class="overflow-x-auto">
                        <table class="glass-table w-full text-sm" style="min-width: 800px;">
                            <thead>
                                <tr class="text-white-50" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                    <th style="width: 16%; font-weight: 600;">Durum</th>
                                    <th style="width: 16%; font-weight: 600;">Öncelik</th>
                                    <th style="width: 16%; font-weight: 600;">Kategori</th>
                                    <th style="width: 16%; font-weight: 600;">Atanan</th>
                                    <th style="width: 16%; font-weight: 600;">SLA Durumu</th>
                                    <th style="width: 20%; font-weight: 600;">Arama</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="p-1">
                                        <select asp-for="StatusFilter" asp-items="Model.StatusList"
                                                class="form-select form-select-sm border-0"
                                                style="background: rgba(255,255,255,0.15); color: black; height: 35px;">
                                        </select>
                                    </td>
                                    <td class="p-1">
                                        <select asp-for="PriorityFilter" asp-items="Model.PriorityList"
                                                class="form-select form-select-sm border-0"
                                                style="background: rgba(255,255,255,0.15); color: black; height: 35px;">
                                        </select>
                                    </td>
                                    <td class="p-1">
                                        <select asp-for="CategoryFilter" asp-items="Model.CategoryList"
                                                class="form-select form-select-sm border-0"
                                                style="background: rgba(255,255,255,0.15); color: black; height: 35px;">
                                        </select>
                                    </td>
                                    <td class="p-1">
                                        <select asp-for="AssigneeFilter" asp-items="Model.AssigneeList"
                                                class="form-select form-select-sm border-0"
                                                style="background: rgba(255,255,255,0.15); color: black; height: 35px;">
                                        </select>
                                    </td>
                                    <td class="p-1">
                                        <select asp-for="SlaFilter"
                                                class="form-select form-select-sm border-0"
                                                style="background: rgba(255,255,255,0.15); color: black; height: 35px;">
                                            <option value="">Tümü</option>
                                            <option value="Breached">🔴 Aşıldı</option>
                                            <option value="AtRisk">🟡 Riskli</option>
                                            <option value="OnTrack">🟢 Normal</option>
                                        </select>
                                    </td>
                                    <td class="p-1">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text border-0" style="background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);">
                                                <i class="fas fa-search"></i>
                                            </span>
                                            <input asp-for="SearchTerm"
                                                   class="form-control border-0"
                                                   placeholder="Ticket, isim, email..."
                                                   style="background: rgba(255,255,255,0.15); color: white; height: 35px;">
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
        
                        <div class="text-end mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                            <button type="submit" class="btn btn-light btn-sm px-4">
                                <i class="fas fa-filter me-2"></i>Filtrele
                            </button>
                        </div>
                    </form>
                </div>

            <!-- Şikayet Listesi -->
                <div class="glass-card p-3 mb-4" style="background: rgba(30, 58, 138, 0.4) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="m-0 font-weight-bold text-white">
                        Şikayet Listesi (@Model.Complaints.Count)
                    </h6>
                </div>
                    <div class="glass-card">
                        <div class="overflow-x-auto">
                            <table class="glass-table w-full text-sm" id="complaintsTable">
                            <thead>
                                <tr>
                                    <th class="border-0">Ticket</th>
                                    <th class="border-0">Müşteri</th>
                                    <th class="border-0">Konu</th>
                                    <th class="border-0">Kategori</th>
                                    <th class="border-0">Öncelik</th>
                                    <th class="border-0">Durum</th>
                                    <th class="border-0">Atanan</th>
                                    <th class="border-0">SLA</th>
                                    <th class="border-0">Süre</th>
                                    <th class="border-0 text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Complaints)
                                {
                                    <tr class="@(item.IsSlaBreached ? "table-danger" : "")">
                                        <td>
                                            <span class="font-monospace fw-bold">@item.TicketNumber</span>
                                            @if (item.CanAutoAssign)
                                            {
                                                <span class="badge bg-secondary ms-1">Yeni</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-circle bg-primary text-white me-2">
                                                    @(item.CustomerName?[0] ?? '?')
                                                </div>
                                                <div>
                                                    <div class="fw-bold">@item.CustomerName</div>
                                                    <div class="small text-muted-white">@item.CustomerEmail</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <a asp-page="./Details" asp-route-id="@item.Id" class="text-decoration-none">
                                                @item.Title
                                            </a>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@item.Category</span></td>
                                        <td>
                                            <span class="badge bg-@item.PriorityBadgeClass">
                                                @item.Priority
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-@item.StatusBadgeClass">
                                                @item.Status
                                            </span>
                                        </td>
                                        <td>
                                            @if (string.IsNullOrEmpty(item.AssignedToName) || item.AssignedToName == "Atanmamış")
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                            else
                                            {
                                                <span>@item.AssignedToName</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="small @((item.IsSlaBreached ? "text-danger fw-bold" : "text-muted-white"))">
                                                @item.SlaStatus
                                            </span>
                                            @if (item.DueDate.HasValue)
                                            {
                                                <div class="small text-muted-white">@item.DueDate.Value.ToString("dd.MM HH:mm")</div>
                                            }
                                        </td>
                                        <td class="text-muted small">@item.TimeElapsed</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Detay">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (item.CanAutoAssign)
                                                {
                                                    <form method="post" asp-page-handler="AutoAssign" asp-route-id="@item.Id" class="d-inline">
                                                        <button type="submit" class="btn btn-outline-success" title="Otomatik Ata">
                                                            <i class="fas fa-magic"></i>
                                                        </button>
                                                    </form>
                                                }
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" 
                                                      onsubmit="return confirm('@item.TicketNumber silinecek. Emin misiniz?');">
                                                    <button type="submit" class="btn btn-outline-danger" title="Sil">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ: Workload Paneli -->
        <div class="col-lg-3">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-users me-2"></i>Takım Workload
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var user in Model.UserWorkloads)
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@user.UserName</h6>
                                    @if (user.IsOverloaded)
                                    {
                                        <span class="badge bg-danger">Yüksek</span>
                                    }
                                </div>
                                <p class="mb-1 small text-muted">@user.Department</p>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <div class="small">
                                        <span class="badge bg-primary">@user.OpenCount açık</span>
                                        @if (user.CriticalCount > 0)
                                        {
                                            <span class="badge bg-danger ms-1">@user.CriticalCount kritik</span>
                                        }
                                    </div>
                                    @if (user.AvgResolutionTime.HasValue)
                                    {
                                        <small class="text-muted">Ort: @(user.AvgResolutionTime / 60)s</small>
                                    }
                                </div>
                                @if (user.BreachedCount > 0)
                                {
                                    <div class="mt-1">
                                        <span class="badge bg-warning text-dark">@user.BreachedCount SLA aşımı</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Hızlı İstatistikler -->
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Kategori Dağılımı</h6>
                </div>
                <div class="card-body">
                    @foreach (var cat in Model.SlaMetrics.ByCategory)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span>@cat.Key</span>
                                <span class="fw-bold">@cat.Value.Total</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                @{
                                    var percentage = Model.SlaMetrics.TotalComplaints > 0 
                                        ? (int)((double)cat.Value.Total / Model.SlaMetrics.TotalComplaints * 100) 
                                        : 0;
                                }
                                <div class="progress-bar" role="progressbar" style="width: @percentage%"></div>
                            </div>
                            @if (cat.Value.Breached > 0)
                            {
                                <small class="text-danger">@cat.Value.Breached aşım</small>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

