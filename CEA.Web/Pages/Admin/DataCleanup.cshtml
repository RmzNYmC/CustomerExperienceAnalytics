@page
@model CEA.Web.Pages.Admin.DataCleanupModel
@{
    ViewData["Title"] = "Veri Temizleme";
}

<h1>🗑️ Test Verilerini Temizle</h1>

<div class="alert alert-warning">
    <strong>Dikkat!</strong> Bu işlem geri alınamaz!
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="card">
    <div class="card-header">
        <h5>Son Yanıtları Sil</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="DeleteLastResponses">
            <div class="mb-3">
                <label>Kaç yanıt silinecek?</label>
                <input type="number" name="count" value="10" class="form-control" min="1" />
            </div>
            
            <div class="mb-3">
                <label>Belirli anket (opsiyonel)</label>
                <select name="surveyId" class="form-select">
                    <option value="">Tümü</option>
                    @foreach (var survey in ViewData["Surveys"] as List<CEA.Core.Entities.Survey> ?? new List<CEA.Core.Entities.Survey>())
                    {
                        <option value="@survey.Id">@survey.Title</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash"></i> Sil
            </button>
        </form>
    </div>
</div>

<div class="mt-3">
    <p>Mevcut toplam yanıt: <strong>@ViewData["TotalResponses"]</strong></p>
</div>