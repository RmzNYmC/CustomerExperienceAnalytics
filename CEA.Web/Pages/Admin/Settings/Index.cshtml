@page
@model CEA.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "Sistem Ayarları";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4><i class="fas fa-cogs me-2"></i>Sistem Ayarları</h4>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- SMTP Ayarları -->
    <div class="glass-card mb-4">
        <div class="card-header bg-transparent border-bottom border-white/10 py-3">
            <h5 class="mb-0 text-white"><i class="fas fa-envelope me-2"></i>Mail (SMTP) Ayarları</h5>
        </div>
        <div class="card-body">
            <!-- SMTP KAYIT FORMU -->
            <form method="post" asp-page-handler="SaveSmtp">
                <div class="row g-3">
                    <!-- Satır 1: Sunucu, Port, SSL -->
                    <div class="col-md-4">
                        <label class="form-label text-white">SMTP Sunucu <span class="text-danger">*</span></label>
                        <input type="text" class="form-control bg-white/10 border-white/20 text-white"
                               asp-for="SmtpSettings.Host" placeholder="smtp.office365.com" required>
                            <span asp-validation-for="SmtpSettings.Host" class="text-danger"></span>
                        </div>
                    
                        <div class="col-md-2">
                            <label class="form-label text-white">Port <span class="text-danger">*</span></label>
                            <input type="number" class="form-control bg-white/10 border-white/20 text-white"
                                   asp-for="SmtpSettings.Port" placeholder="587" required>
                            </div>
                    
                            <div class="col-md-2">
                                <div class="form-check mt-4 pt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="SmtpSettings.EnableSsl">
                                        <label class="form-check-label text-white">SSL/TLS</label>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label text-white">Gönderici Adı <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control bg-white/10 border-white/20 text-white"
                                           asp-for="SmtpSettings.FromName" placeholder="Turkon Lojistik" required>
                                    </div>

                                    <!-- Satır 2: Email, Kullanıcı Adı -->
                                    <div class="col-md-6">
                                        <label class="form-label text-white">Gönderici E-posta <span class="text-danger">*</span></label>
                                        <input type="email" class="form-control bg-white/10 border-white/20 text-white"
                                               asp-for="SmtpSettings.FromEmail" placeholder="scanner@turkonlogistics.com" required>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label text-white">Kullanıcı Adı <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control bg-white/10 border-white/20 text-white"
                                                   asp-for="SmtpSettings.Username" placeholder="scanner@turkonlogistics.com" required>
                                            </div>

                                            <!-- Satır 3: Şifre -->
                                            <div class="col-md-6">
                                                <label class="form-label text-white">Şifre / Uygulama Şifresi</label>
                                                <input type="password" class="form-control bg-white/10 border-white/20 text-white"
                                                       asp-for="SmtpSettings.Password" placeholder="Değiştirmek için yazın">
                                                    <small class="text-white/50">Boş bırakırsanız mevcut şifre korunur</small>
                                                </div>
                                            </div>

                                            <div class="mt-4">
                                                <button type="submit" class="btn btn-glass-primary">
                                                    <i class="fas fa-save me-2"></i>Ayarları Kaydet
                                                </button>
                                            </div>
                                        </form>

                                        <hr class="border-white/10 my-4">

                                        <!-- TEST MAİLİ FORMU -->
                                        <h6 class="text-white mb-3"><i class="fas fa-paper-plane me-2"></i>Test Maili Gönder</h6>
                                        <form method="post" asp-page-handler="SendTest">
                                            <div class="row g-3 align-items-end">
                                                <div class="col-md-4">
                                                    <label class="form-label text-white">Test E-posta Adresi</label>
                                                    <input type="email" class="form-control bg-white/10 border-white/20 text-white"
                                                           asp-for="TestEmail" placeholder="test@email.com">
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label text-white">Opsiyonel Mesaj</label>
                                                        <input type="text" class="form-control bg-white/10 border-white/20 text-white"
                                                               asp-for="TestMessage" placeholder="Test mesajı...">
                                                        </div>
                                                        <div class="col-md-4">
                                                            <button type="submit" class="btn btn-outline-success w-100">
                                                                <i class="fas fa-paper-plane me-2"></i>Test Maili Gönder
                                                            </button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    @section Scripts {
                                        <partial name="_ValidationScriptsPartial" />
                                    }