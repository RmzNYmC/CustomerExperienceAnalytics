@page
@model CEA.Web.Pages.Admin.Audit.IndexModel
@{
    ViewData["Title"] = "Audit Log - Son Aktiviteler";
}

<h1>📋 Son Aktiviteler</h1>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tarih</th>
                <th>Kullanıcı</th>
                <th>İşlem</th>
                <th>Entity</th>
                <th>IP Adresi</th>
                <th>Durum</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.RecentActivities)
            {
                <tr>
                    <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@log.UserName</td>
                    <td>
                        <span class="badge @(log.Action == "Create" ? "bg-success" :
                                                                                                      log.Action == "Delete" ? "bg-danger" :
                                                                                                      log.Action == "Assign" ? "bg-info" : "bg-secondary")">
                            @log.Action
                        </span>
                    </td>
                    <td>@log.EntityType #@log.EntityId</td>
                    <td>@log.IpAddress</td>
                    <td>
                        @if (log.Success)
                        {
                            <span class="badge bg-success">✓</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">✗</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>