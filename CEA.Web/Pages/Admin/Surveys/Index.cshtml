@page
@model CEA.Web.Pages.Admin.Surveys.IndexModel
@{
    ViewData["Title"] = "Anket Yönetimi";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Anket Yönetimi</h4>
    <a href="/Admin/Surveys/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Yeni Anket Oluştur
    </a>
</div>

<div class="stat-card">
    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th>Anket Adı</th>
                    <th>Durum</th>
                    <th>Dönem</th>
                    <th>Yanıt</th>
                    <th>Link</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var survey in Model.Surveys)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@survey.Title</div>
                            <small class="text-muted">@survey.CreatedAt.ToString("dd.MM.yyyy")</small>
                        </td>
                        <td>
                            <span class="badge bg-@survey.StatusClass">
                                @survey.Status
                            </span>
                        </td>
                        <td>@survey.AnalysisYear @(survey.AnalysisMonth.HasValue ? $"- {survey.AnalysisMonth:00}" : "")</td>
                        <td>@survey.ResponseCount</td>
                        <td>
                            @if (survey.Status == "Active")
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <code class="small">/s/@survey.PublicToken</code>
                                    <button class="btn btn-sm btn-outline-primary"
                                            onclick="copyLink('@survey.PublicToken')"
                                            title="Linki Kopyala">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                    <a href="/s/@survey.PublicToken" target="_blank" class="btn btn-sm btn-outline-success" title="Önizle">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Taslak - Aktif değil</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/Admin/Surveys/Edit?id=@survey.Id" class="btn btn-outline-primary" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Admin/Analytics?surveyId=@survey.Id" class="btn btn-outline-success" title="Analiz">
                                    <i class="bi bi-graph-up"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function copyToClipboard(token) {
        navigator.clipboard.writeText(window.location.origin + '/s/' + token);
        alert('Link kopyalandı!');
    }
</script>