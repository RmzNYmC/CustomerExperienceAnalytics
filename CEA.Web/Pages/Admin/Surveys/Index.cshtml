@page
@model CEA.Web.Pages.Admin.Surveys.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Anket Yönetimi";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-white fw-bold">
        <i class="fas fa-clipboard-list me-2 text-blue-300"></i>
        Anket Yönetimi
    </h4>
    <a href="/Admin/Surveys/Create" class="btn btn-glass-primary">
        <i class="fas fa-plus me-2"></i>Yeni Anket Oluştur
    </a>
</div>

<div class="glass-card p-4" style="background: rgba(30, 58, 138, 0.4) !important; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
    <div class="table-responsive">
        <table class="glass-table" style="background: transparent !important; color: white;">
            <thead>
                <tr>
                    <th>Anket Adı</th>
                    <th>Durum</th>
                    <th>Dönem</th>
                    <th>Yanıt</th>
                    <th>Link</th>
                    <th style="width: 180px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var survey in Model.Surveys)
                {
                    <tr style="background: rgba(255, 255, 255, 0.05); color: white;">
                        <td>
                            <div class="fw-semibold">@survey.Title</div>
                            <small class="text-white/50">@survey.CreatedAt.ToString("dd.MM.yyyy")</small>
                        </td>
                        <td>
                            <span class="badge badge-glass-@survey.StatusClass">
                                @survey.Status
                            </span>
                        </td>
                        <td>@survey.AnalysisYear @(survey.AnalysisMonth.HasValue ? $"- {survey.AnalysisMonth:00}" : "")</td>
                        <td>
                            <span class="badge bg-white/10">@survey.ResponseCount</span>
                        </td>
                        <td>
                            @if (survey.Status == "Active")
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <code class="small bg-black/30 px-2 py-1 rounded text-white">/s/@survey.PublicToken</code>
                                    <button class="btn btn-sm btn-outline-light"
                                            onclick="copyLink('@survey.PublicToken')"
                                            title="Linki Kopyala">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                    <a href="/s/@survey.PublicToken" target="_blank" class="btn btn-sm btn-outline-success" title="Önizle">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="badge badge-glass-warning">Taslak</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/Admin/Surveys/Edit?id=@survey.Id" class="btn btn-outline-light" title="Düzenle">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="/Admin/Analytics?surveyId=@survey.Id" class="btn btn-outline-info" title="Analiz">
                                    <i class="fas fa-chart-line"></i>
                                </a>
                                <a href="/Admin/Surveys/SendMail?surveyId=@survey.Id" class="btn btn-outline-warning" title="Mail Gönder">
                                    <i class="fas fa-envelope"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger"
                                        onclick="confirmDelete(@survey.Id, '@survey.Title.Replace("'", "\\'")')"
                                        title="Sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Silme Onay Modalı -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-white/10">
                <h5 class="modal-title text-white">
                    <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                    Anket Silme Onayı
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-white">
                <p><strong id="deleteSurveyTitle"></strong> anketini silmek istediğinize emin misiniz?</p>
                <p class="text-white/60 small mb-0">
                    <i class="fas fa-info-circle me-1"></i>
                    Bu işlem geri alınamaz. Anket ve tüm yanıtları silinecektir.
                </p>
            </div>
            <div class="modal-footer border-white/10">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">İptal</button>
                <form method="post" asp-page-handler="Delete" class="d-inline">
                    <input type="hidden" name="id" id="deleteSurveyId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyLink(token) {
            const fullUrl = window.location.origin + '/s/' + token;
            navigator.clipboard.writeText(fullUrl).then(() => {
                // Toast bildirimi
                const toast = document.createElement('div');
                toast.className = 'position-fixed top-0 end-0 p-3';
                toast.style.zIndex = '9999';
                toast.innerHTML = `
                    <div class="glass-card p-3 text-white" style="min-width: 250px;">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Link kopyalandı!
                        <div class="small text-white/60 mt-1">${fullUrl}</div>
                    </div>
                `;
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 3000);
            }).catch(err => {
                prompt('Linki kopyalayın:', fullUrl);
            });
        }

        function confirmDelete(id, title) {
            document.getElementById('deleteSurveyId').value = id;
            document.getElementById('deleteSurveyTitle').textContent = title;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
}