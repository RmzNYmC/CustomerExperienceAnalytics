@page
@model CEA.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    
    // Emoji ve renk belirleme (PositivePercentage'e göre)
    var satisfactionEmoji = "😡";
    var satisfactionColor = "text-red-500";
    var satisfactionText = "Olumsuz";
    
    if (Model.Summary.PositivePercentage >= 70)
    {
        satisfactionEmoji = "😊";
        satisfactionColor = "text-green-400";
        satisfactionText = "Mükemmel";
    }
    else if (Model.Summary.PositivePercentage >= 40)
    {
        satisfactionEmoji = "😐";
        satisfactionColor = "text-yellow-400";
        satisfactionText = "Orta";
    }
}

<div class="grid grid-cols-12 gap-6">
    <!-- Üst Kısım: Ana Gauge ve Özet -->
    <div class="col-span-12 lg:col-span-8">
        <!-- Ana Memnuniyet Göstergesi (Gauge) -->
        <div class="glass-card p-8 relative overflow-hidden mb-6">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 to-transparent pointer-events-none"></div>
            
            <h2 class="text-2xl font-bold text-center mb-6 relative z-10">Müşteri Memnuniyet Analizi</h2>
            
            <div class="gauge-container relative">
                <canvas id="satisfactionGauge" width="400" height="200"></canvas>
                
                <!-- Merkez İçerik -->
                <div class="gauge-center flex flex-col items-center">
                    <span class="text-6xl mb-2 @satisfactionColor">@satisfactionEmoji</span>
                    <span class="text-5xl font-bold text-white">@Model.Summary.PositivePercentage.ToString("F0")%</span>
                    <span class="text-sm text-white/60 mt-1">@satisfactionText</span>
                    <div class="flex gap-1 mt-2 star-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= (Model.Summary.PositivePercentage / 20)) // %20 = 1 yıldız
                            {
                                <i class="fas fa-star"></i>
                            }
                            else if (i - 0.5 <= ((double)Model.Summary.PositivePercentage / 20))
                            {
                                <i class="fas fa-star-half-alt"></i>
                            }
                            else
                            {
                                <i class="far fa-star empty"></i>
                            }
                        }
                    </div>
                </div>
                
                <!-- Dekoratif İkonlar -->
                <div class="absolute left-4 bottom-4 text-5xl opacity-80">
                    <i class="fas fa-truck text-red-500"></i>
                </div>
                <div class="absolute right-4 bottom-4 text-5xl opacity-80">
                    <i class="fas fa-ship text-blue-300"></i>
                </div>
            </div>
        </div>

        
        <!-- Emoji İstatistik Kartları -->
        <div class="grid grid-cols-4 gap-4">
            <div class="stat-card-turkon border-l-4 border-red-500">
                <div class="text-4xl">😡</div>
                <div>
                    <p class="text-2xl font-bold text-red-400">@Model.Summary.NegativePercentage.ToString("F0")%</p>
                    <p class="text-sm text-white/60">Olumsuz</p>
                </div>
            </div>
            <div class="stat-card-turkon border-l-4 border-yellow-500">
                <div class="text-4xl">😐</div>
                <div>
                    <p class="text-2xl font-bold text-yellow-400">@Model.Summary.NeutralPercentage.ToString("F0")%</p>
                    <p class="text-sm text-white/60">Orta</p>
                </div>
            </div>
            <div class="stat-card-turkon border-l-4 border-green-500">
                <div class="text-4xl">😊</div>
                <div>
                    <p class="text-2xl font-bold text-green-400">@Model.Summary.PositivePercentage.ToString("F0")%</p>
                    <p class="text-sm text-white/60">Olumlu</p>
                </div>
            </div>
            <div class="stat-card-turkon border-l-4 border-blue-400">
                <div class="text-4xl">📊</div>
                <div>
                    <p class="text-2xl font-bold text-blue-300">@Model.Summary.TotalResponsesThisMonth.ToString("N0")</p>
                    <p class="text-sm text-white/60">Bu Ay Yanıt</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ Kısım: Donut Chart ve İşlemler -->
    <div class="col-span-12 lg:col-span-4 space-y-6">
        <!-- Memnuniyet Dağılımı (Donut) -->
        <div class="glass-card p-6">
            <h3 class="text-lg font-semibold mb-4">Müşteri Memnuniyet Oranı</h3>
            <div class="relative h-48">
                <canvas id="satisfactionDonut"></canvas>
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div class="text-center">
                        <span class="text-3xl font-bold @satisfactionColor">@Model.Summary.PositivePercentage.ToString("F0")%</span>
                        <p class="text-xs text-white/60">@satisfactionText</p>
                    </div>
                </div>
            </div>
            <div class="space-y-3 mt-4">
                <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full bg-red-500"></div>
                        <span class="text-white/80">Olumsuz</span>
                    </div>
                    <span class="font-bold">@Model.Summary.NegativePercentage.ToString("F1")%</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                        <span class="text-white/80">Orta</span>
                    </div>
                    <span class="font-bold">@Model.Summary.NeutralPercentage.ToString("F1")%</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        <span class="text-white/80">Olumlu</span>
                    </div>
                    <span class="font-bold">@Model.Summary.PositivePercentage.ToString("F1")%</span>
                </div>
            </div>
        </div>

        <!-- Hızlı İşlemler -->
        <div class="glass-card p-6">
            <h6 class="mb-4 font-semibold">Hızlı İşlemler</h6>
            <div class="d-grid gap-3">
                <a href="/Admin/Surveys/Create" class="btn btn-glass-primary text-white">
                    <i class="fas fa-plus me-2"></i>Yeni Anket Oluştur
                </a>
                <a href="/Admin/Analytics/Index" class="btn btn-outline-light border-white/20 hover:bg-white/10">
                    <i class="fas fa-chart-line me-2"></i>Detaylı Analiz
                </a>
                <a href="/Admin/Complaints/Index" class="btn btn-outline-danger border-red-500/30 hover:bg-red-500/10 text-red-300">
                    <i class="fas fa-inbox me-2"></i>Şikayetleri Yönet
                </a>
            </div>
        </div>
    </div>

    <!-- Orta Kısım: Trend Grafiği -->
    <div class="col-span-12 lg:col-span-8">
        <div class="glass-card p-6">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-semibold">Müşteri Memnuniyeti Trendleri</h3>
                <div class="flex gap-2">
                    <span class="badge badge-glass-success">Toplam: +2.59%</span>
                </div>
            </div>
            <div class="h-80">
                <canvas id="trendChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Toplam İstatistikler -->
    <div class="col-span-12 lg:col-span-4">
        <div class="glass-card p-6 h-full flex flex-col">
            <h3 class="text-lg font-semibold mb-4">Toplam Geri Bildirimler</h3>
            <div class="text-center mb-6">
                <p class="text-5xl font-bold text-white glow-effect inline-block px-4 py-2 rounded-lg">
                    @Model.Summary.TotalFeedbackCount.ToString("N0")
                </p>
                <div class="flex items-center justify-center gap-2 mt-3 text-green-400">
                    <i class="fas fa-arrow-up"></i>
                    @{
                        // Geçen ay ile karşılaştırma (basit hesaplama)
                        var previousMonthCount = Model.Summary.MonthlyTrend.Count > 1 ?
                            Model.Summary.MonthlyTrend[Model.Summary.MonthlyTrend.Count - 2].Count : 0;
                        var currentMonthCount = Model.Summary.MonthlyTrend.LastOrDefault()?.Count ?? 0;
                        var changePercent = previousMonthCount > 0 ?
                            ((currentMonthCount - previousMonthCount) / (double)previousMonthCount * 100) : 5.3;
                    }
                    <span>@changePercent.ToString("F1")%</span>
                    <span class="text-white/50 text-sm">geçen aya göre</span>
                </div>
            </div>
        
            <div class="flex justify-center gap-6 text-sm mb-6">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-green-500"></div>
                    <span class="text-white/80">Olumlu: @Model.Summary.PositiveCount.ToString("N0")</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                    <span class="text-white/80">Orta: @Model.Summary.NeutralCount.ToString("N0")</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-red-500"></div>
                    <span class="text-white/80">Olumsuz: @Model.Summary.NegativeCount.ToString("N0")</span>
                </div>
            </div>

            <!-- Mini Bar Chart -->
            <div class="flex-1 flex items-end justify-center gap-2 mt-auto">
    @foreach (var trend in Model.Summary.MonthlyTrend.Take(6))
    {
        var maxValue = Model.Summary.MonthlyTrend.Max(m => m.Count);
        maxValue = maxValue == 0 ? 1 : maxValue; // Sıfıra bölünme hatasını önle
        var heightPercent = (trend.Count / (double)maxValue) * 100;
        var opacity = 0.3 + (heightPercent / 200); // Yüksekliğe göre opaklık
        <div class="w-8 rounded-t transition-all hover:scale-110 relative group" 
             style="height: @heightPercent.ToString("F0")%; 
                    background: rgba(59, 130, 246, @opacity.ToString("F2").Replace(",","."));">
            <div class="absolute -top-8 left-1/2 transform -translate-x-1/2 bg-black/80 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">
                @trend.Count
            </div>
        </div>
    }
</div>
<div class="flex justify-center gap-4 mt-2 text-xs text-white/40">
    @foreach (var trend in Model.Summary.MonthlyTrend.Take(6))
    {
        <span>@trend.Label.Split('/')[0]</span> <!-- Ay kısmını göster -->
    }
</div>
        </div>
    </div>

    <!-- Alt Kısım: Tablolar -->
    <div class="col-span-12 lg:col-span-6">
        <div class="glass-card p-6">
            <div class="flex justify-between items-center mb-4">
                <h6 class="font-semibold">Son Anketler</h6>
                <a href="/Admin/Surveys/Index" class="text-sm text-blue-300 hover:text-blue-200">Tümünü Gör →</a>
            </div>
            <div class="overflow-x-auto">
                <table class="glass-table w-full text-sm">
                    <thead>
                        <tr>
                            <th class="text-left">Anket</th>
                            <th class="text-center">Durum</th>
                            <th class="text-center">Yanıt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var survey in Model.RecentSurveys)
                        {
                            <tr class="border-b border-white/10">
                                <td class="py-3">
                                    <div class="font-semibold">@survey.Title</div>
                                    <div class="text-xs text-white/50">@survey.CreatedAt.ToString("dd.MM.yyyy")</div>
                                </td>
                                <td class="text-center">
                                    @switch (survey.Status)
                                    {
                                        case CEA.Core.Enum.SurveyStatus.Active:
                                            <span class="badge badge-glass-success">Aktif</span>
                                            break;
                                        case CEA.Core.Enum.SurveyStatus.Draft:
                                            <span class="badge badge-glass-warning">Taslak</span>
                                            break;
                                        default:
                                            <span class="badge bg-white/10">@survey.Status</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center font-mono">@survey.ResponseCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-span-12 lg:col-span-6">
        <div class="glass-card p-6">
            <div class="flex justify-between items-center mb-4">
                <h6 class="font-semibold">Son Şikayetler</h6>
                <a href="/Admin/Complaints/Index" class="text-sm text-red-300 hover:text-red-200">Tümünü Gör →</a>
            </div>
            <div class="overflow-x-auto">
                <table class="glass-table w-full text-sm">
                    <thead>
                        <tr>
                            <th class="text-left">Ticket</th>
                            <th class="text-center">Öncelik</th>
                            <th class="text-center">Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var complaint in Model.RecentComplaints)
                        {
                            <tr class="border-b border-white/10">
                                <td class="py-3">
                                    <a href="/Admin/Complaints/Details?id=@complaint.Id" class="font-semibold text-blue-300 hover:text-blue-200">
                                        @complaint.TicketNumber
                                    </a>
                                    <div class="text-xs text-white/50">@complaint.CustomerName</div>
                                </td>
                                <td class="text-center">
                                    @if (complaint.Priority == "Critical")
                                    {
                                        <span class="badge badge-glass-danger">Kritik</span>
                                    }
                                    else if (complaint.Priority == "High")
                                    {
                                        <span class="badge badge-glass-warning">Yüksek</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-white/10">@complaint.Priority</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge @(complaint.Status == "New" ? "badge-glass-danger" : complaint.Status == "InProgress" ? "bg-blue-500/20 text-blue-300" : "badge-glass-success")">
                                        @complaint.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Debug için - verileri kontrol et
        console.log('MonthlyTrend Data:', @Html.Raw(Json.Serialize(Model.Summary.MonthlyTrend)));
        
        // Gauge Chart (Yarım Daire)
        const gaugeCtx = document.getElementById('satisfactionGauge')?.getContext('2d');
        if (gaugeCtx) {
            new Chart(gaugeCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Olumsuz', 'Orta', 'Olumlu'],
                    datasets: [{
                        data: [
                            @(Model.Summary.NegativePercentage), 
                            @(Model.Summary.NeutralPercentage), 
                            @(Model.Summary.PositivePercentage)
                        ],
                        backgroundColor: ['#ef4444', '#eab308', '#22c55e'],
                        borderWidth: 0,
                        circumference: 180,
                        rotation: 270,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: { legend: { display: false } }
                }
            });
        }

        // Donut Chart
        const donutCtx = document.getElementById('satisfactionDonut')?.getContext('2d');
        if (donutCtx) {
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Olumsuz', 'Orta', 'Olumlu'],
                    datasets: [{
                        data: [
                            @(Model.Summary.NegativePercentage), 
                            @(Model.Summary.NeutralPercentage), 
                            @(Model.Summary.PositivePercentage)
                        ],
                        backgroundColor: ['#ef4444', '#eab308', '#22c55e'],
                        borderWidth: 0,
                        cutout: '75%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                }
            });
        }

        // Trend Chart - DÜZELTİLMİŞ
        const trendChartElement = document.getElementById('trendChart');
        if (trendChartElement) {
            // Razor'dan gelen veriyi güvenli şekilde al
            const monthlyTrend = @Html.Raw(Json.Serialize(Model.Summary.MonthlyTrend));
            
            console.log('Trend Chart Data:', monthlyTrend);
            
            if (monthlyTrend && monthlyTrend.length > 0) {
                const trendCtx = trendChartElement.getContext('2d');
                
                // Maksimum değeri bul (grafik ölçeklendirmesi için)
                const maxCount = Math.max(...monthlyTrend.map(x => x.count || x.value || 0));
                const yMax = maxCount < 5 ? 5 : Math.ceil(maxCount * 1.2); // Minimum 5 olsun
                
                new Chart(trendCtx, {
                    type: 'bar',
                    data: {
                        labels: monthlyTrend.map(x => {
                            const parts = (x.label || '').split('/');
                            if (parts.length === 2) {
                                const monthNames = ['', 'Oca', 'Şub', 'Mar', 'Nis', 'May', 'Haz', 'Tem', 'Ağu', 'Eyl', 'Eki', 'Kas', 'Ara'];
                                const month = parseInt(parts[0]);
                                return monthNames[month] || x.label;
                            }
                            return x.label;
                        }),
                        datasets: [{
                            label: 'Yanıt Sayısı',
                            data: monthlyTrend.map(x => x.count || x.value || 0),
                            backgroundColor: 'rgba(59, 130, 246, 0.8)',
                            borderColor: 'rgba(59, 130, 246, 1)',
                            borderWidth: 1,
                            borderRadius: 6,
                            order: 2
                        }, {
                            label: 'Trend',
                            data: monthlyTrend.map(x => x.count || x.value || 0),
                            type: 'line',
                            borderColor: '#4ade80',
                            backgroundColor: 'rgba(74, 222, 128, 0.1)',
                            borderWidth: 3,
                            tension: 0.4,
                            pointBackgroundColor: '#4ade80',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 5,
                            fill: false,
                            order: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: { 
                                display: true,
                                labels: { 
                                    color: 'white',
                                    usePointStyle: true,
                                    padding: 20
                                }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                                titleColor: 'white',
                                bodyColor: 'white',
                                padding: 12,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        return context.dataset.label + ': ' + context.parsed.y + ' yanıt';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: yMax,
                                ticks: {
                                    color: 'rgba(255, 255, 255, 0.7)',
                                    stepSize: 1,
                                    precision: 0
                                },
                                grid: {
                                    color: 'rgba(255, 255, 255, 0.1)',
                                    drawBorder: false
                                }
                            },
                            x: {
                                ticks: {
                                    color: 'rgba(255, 255, 255, 0.7)'
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            } else {
                // Veri yoksa mesaj göster
                trendChartElement.parentElement.innerHTML = 
                    '<div class="d-flex align-items-center justify-content-center h-100 text-white/50">' +
                    '<div class="text-center"><i class="fas fa-chart-line fa-3x mb-3"></i><br>Henüz trend verisi bulunmuyor</div></div>';
            }
        }
    </script>
}
}