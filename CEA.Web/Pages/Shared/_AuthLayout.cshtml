<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEA Giriş</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e40af 50%, #0ea5e9 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .turkon-logo {
            width: 60px;
            height: 60px;
            background: #dc2626;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
    </style>
    
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                @* <!-- Logo -->
                <div class="text-center mb-4">
    <img src="~/images/log_logistic.png" alt="TURKON Logo" style="height: 80px; width: auto;" />
</div> *@
<!-- Logo yuvarlak gölgeli -->
<div class="text-center mb-4">
    <img src="~/images/log_logistic.png" alt="TURKON Logo"  class="mx-auto d-block"
         style="height: 100px; width: auto; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);" />
</div>
                
                <!-- Auth Card -->
                <div class="auth-card p-4 p-md-5">
                    @RenderBody()
                </div>
                
                <!-- Alt Bilgi -->
                <div class="text-center mt-4 text-white/60 text-sm">
                    <p>&copy; 2026 TURKON LOJİSTIK - CEA Müşteri Deneyimi Analizi</p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>