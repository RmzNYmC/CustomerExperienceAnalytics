<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
    :root {
        --brand-color: #2563eb;
        --brand-light: #dbeafe;
    }

    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .survey-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .survey-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    .survey-header {
        background: var(--brand-color);
        color: white;
        padding: 3rem 2rem;
        text-align: center;
    }

    .survey-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .survey-body {
        padding: 2.5rem;
    }

    .question-block {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .question-block:last-child {
        border-bottom: none;
    }

    .question-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--brand-color);
        color: white;
        border-radius: 50%;
        font-weight: 600;
        font-size: 0.875rem;
        margin-right: 0.75rem;
    }

    .question-text {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 1rem;
    }

    .required-badge {
        color: #ef4444;
        font-size: 0.75rem;
        margin-left: 0.5rem;
    }

    /* Rating Stars */
    .rating-group {
        display: flex;
        gap: 0.5rem;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

    .rating-input {
        display: none;
    }

    .rating-label {
        cursor: pointer;
        font-size: 2.5rem;
        color: #d1d5db;
        transition: all 0.2s;
    }

    .rating-label:hover,
    .rating-label:hover ~ .rating-label,
    .rating-input:checked ~ .rating-label {
        color: #fbbf24;
    }

    /* NPS Scale */
    .nps-scale {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .nps-option {
        flex: 1;
        min-width: 40px;
    }

    .nps-input {
        display: none;
    }

    .nps-label {
        display: block;
        text-align: center;
        padding: 1rem 0.5rem;
        background: #f3f4f6;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
    }

    .nps-input:checked + .nps-label {
        background: var(--brand-color);
        color: white;
    }

    .nps-label:hover {
        background: #e5e7eb;
    }

    .nps-input:checked + .nps-label:hover {
        background: #1d4ed8;
    }

    .nps-legend {
        display: flex;
        justify-content: space-between;
        margin-top: 0.5rem;
        font-size: 0.875rem;
        color: #6b7280;
    }

    /* Choice Options */
    .choice-option {
        display: block;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        background: #f9fafb;
        border: 2px solid transparent;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .choice-option:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
    }

    .choice-input:checked + .choice-option {
        background: var(--brand-light);
        border-color: var(--brand-color);
    }

    .choice-input {
        display: none;
    }

    /* Progress Bar */
    .progress-container {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: rgba(255,255,255,0.3);
        z-index: 1000;
    }

    .progress-bar-custom {
        height: 100%;
        background: white;
        transition: width 0.3s ease;
    }

    /* Thank You Page */
    .thank-you-icon {
        width: 100px;
        height: 100px;
        background: #dcfce7;
        color: #16a34a;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 2rem;
    }

    .btn-submit {
        background: var(--brand-color);
        color: white;
        border: none;
        padding: 1rem 3rem;
        font-size: 1.125rem;
        font-weight: 600;
        border-radius: 12px;
        width: 100%;
        transition: all 0.2s;
    }

    .btn-submit:hover:not(:disabled) {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
    }

    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .spinner {
        display: none;
        width: 20px;
        height: 20px;
        border: 2px solid #ffffff;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-right: 0.5rem;
        vertical-align: middle;
    }

    /* DÜZELTİLDİ: @@keyframes yerine @@keyframes */
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading .spinner {
        display: inline-block;
    }

    /* Validation */
    .validation-message {
        color: #ef4444;
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: none;
    }

    .was-validated .validation-message {
        display: block;
    }

    /* DÜZELTİLDİ: @@media yerine @@media */
    @@media (max-width: 576px) {
        .survey-header {
            padding: 2rem 1rem;
        }
        .survey-header h1 {
            font-size: 1.25rem;
        }
        .survey-body {
            padding: 1.5rem;
        }
        .rating-label {
            font-size: 1.75rem;
        }
    }
</style>
</head>
<body>
    <!-- Progress Bar -->
    <div class="progress-container">
        <div class="progress-bar-custom" id="progressBar" style="width: 0%"></div>
    </div>

    <div class="survey-container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Progress bar update
        function updateProgress(current, total) {
        const percent = (current / total) * 100;
        document.getElementById('progressBar').style.width = percent + '%';
        }

        // Form validation
        document.querySelectorAll('form').forEach(form => {
        form.addEventListener('submit', function(e) {
        if (!form.checkValidity()) {
        e.preventDefault();
        e.stopPropagation();
        }
        form.classList.add('was-validated');
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>