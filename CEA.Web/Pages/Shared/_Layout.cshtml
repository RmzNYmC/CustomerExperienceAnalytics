<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Müşteri Memnuniyeti Analizi</title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Font Awesome (Kamyon/Gemi ikonları için) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Tailwind CSS (Gradient ve modern utility class'lar için) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        'turkon': {
        dark: '#0f172a',
        primary: '#1e40af',
        secondary: '#0ea5e9',
        accent: '#06b6d4',
        }
        }
        }
        }
        }
    </script>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="bg-gradient-to-br from-blue-900 via-blue-800 to-sky-600 min-h-screen text-white overflow-hidden">

    <div class="flex h-screen">
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900/50 backdrop-blur-xl border-r border-white/10 flex flex-col">
            <!-- Logo -->
            <div class="p-6 flex items-center gap-3">
                <div class="w-10 h-10 bg-red-600 rounded-lg flex items-center justify-center shadow-lg">
                    <i class="fas fa-truck text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="font-bold text-lg tracking-wide">TURKON</h1>
                    <p class="text-xs text-white/60">LOJİSTİK</p>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-4 py-6 space-y-2">
                <a href="/Admin/Dashboard" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Dashboard") == true ? "active" : "")">
                    <i class="fas fa-home w-6"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/Surveys/Index" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Survey") == true ? "active" : "")">
                    <i class="fas fa-clipboard-check w-6"></i>
                    <span>Anket Yönetimi</span>

                    <!-- ✅ BURAYA EKLEYİN -->
                    <a href="/Admin/Customers" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Customer") == true ? "active" : "")">
                        <i class="fas fa-address-book w-6"></i>
                        <span>Müşteri Yönetimi</span>
                    </a>

                </a>
                <a href="/Admin/Analytics/Index" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Analytics") == true ? "active" : "")">
                    <i class="fas fa-chart-line w-6"></i>
                    <span>Analiz & Raporlar</span>
                </a>
                <a href="/Admin/Complaints/Index" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Complaint") == true ? "active" : "")">
                    <i class="fas fa-exclamation-triangle w-6"></i>
                    <span>Şikayet Yönetimi</span>
                    <span class="badge bg-danger ms-auto" id="openComplaintsBadge" style="display:none;">0</span>
                </a>
                <a href="/Admin/Users/Index" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("User") == true ? "active" : "")">
                    <i class="fas fa-users w-6"></i>
                    <span>Kullanıcı Yönetimi</span>
                </a>
                
                <div class="mt-8 pt-6 border-t border-white/10">
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sidebar-item">
    <i class="fas fa-user-cog w-6"></i>
    <span>Profilim</span>
</a>
                    </a>
                    <a href="/Admin/Settings" class="sidebar-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Settings") == true ? "active" : "")">
                        <i class="fas fa-cogs w-6"></i>
                        <span>Sistem Ayarları</span>
                    </a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                    <button type="submit" class="sidebar-item w-100 text-start text-danger border-0 bg-transparent">
                        <i class="fas fa-sign-out-alt w-6"></i>
                        <span>Çıkış Yap</span>
                    </button>
                </form>
                </div>
            </nav>

            <!-- Alt Kamyon Görseli -->
        <div class="mt-auto p-4 flex flex-col items-center opacity-50 hover:opacity-80 transition-opacity">
            <img src="~/images/truck.png"
                 alt="Tır"
                 class="w-24 h-auto mb-2 drop-shadow-lg" />
            <span class="text-white/40 text-xs tracking-wider">LOJİSTİK</span>
        </div>
            @* <div class="p-4 mt-auto">
                <div class="flex flex-col items-center text-white/20 text-6xl pb-4">
                    <i class="fas fa-truck-moving"></i>
                </div>
            </div> *@
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-16 bg-white/5 backdrop-blur-md border-b border-white/10 flex items-center justify-between px-8">
                <h2 class="text-xl font-semibold">Müşteri Memnuniyet Analizi</h2>
                
                <div class="flex items-center gap-6">
                    <!-- Arama -->
                    <div class="relative hidden md:block">
                        <input type="text" placeholder="Ara..."
                               class="bg-white/10 border border-white/20 rounded-full px-4 py-2 pl-10 text-sm focus:outline-none focus:border-white/40 w-64 text-white placeholder-white/50">
                        <i class="fas fa-search absolute left-3 top-3 text-white/40"></i>
                    </div>

                    <!-- Bildirim -->
                    <button class="relative p-2 hover:bg-white/10 rounded-full transition">
                        <i class="fas fa-bell text-white/70"></i>
                        <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>

                    <!-- Profil -->
                    <div class="flex items-center gap-3">
                        <div class="text-end hidden sm:block">
                            <div class="text-sm font-semibold">@User.Identity?.Name</div>
                            <div class="text-xs text-white/60">@User.FindFirst("http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value</div>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center border-2 border-white/30">
                            <i class="fas fa-user text-white"></i>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-8">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Açık şikayet sayısını kontrol et
        async function checkOpenComplaints() {
        try {
        const response = await fetch('/api/complaints/open-count');
        const count = await response.json();
        const badge = document.getElementById('openComplaintsBadge');
        if (count > 0) {
        badge.textContent = count > 99 ? '99+' : count;
        badge.style.display = 'inline-block';
        }
        } catch (e) {
        console.error('Şikayet sayısı alınamadı:', e);
        }
        }
        checkOpenComplaints();
        setInterval(checkOpenComplaints, 60000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- SignalR Client Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        // SignalR Bağlantısı
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .withAutomaticReconnect([0, 2000, 5000, 10000, 30000]) // Otomatik yeniden bağlanma
        .build();

        // Bildirim alındığında
        connection.on("ReceiveNotification", function(data) {
        showToast(data.title, data.message, data.type, data.link);
        
        // Bildirim sesi (isteğe bağlı)
        if (data.type === 'danger' || data.type === 'warning') {
        playNotificationSound();
        }
        });

        // Dashboard güncelleme sinyali
        connection.on("DashboardUpdate", function(data) {
        console.log("Dashboard güncellendi:", data);
        // Sayfayı yenile veya sadece verileri yenile
        if (window.location.pathname.includes('/Admin/Dashboard')) {
        setTimeout(() => location.reload(), 2000);
        }
        });

        // Bağlantıyı başlat
        connection.start()
        .then(() => console.log("SignalR bağlantısı kuruldu"))
        .catch(err => console.error("SignalR bağlantı hatası:", err));

        // Toast bildirim gösterme fonksiyonu
        function showToast(title, message, type, link) {
        const toastContainer = document.getElementById('toast-container');
        if (!toastContainer) {
        // Container yoksa oluştur
        const container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'position-fixed top-0 end-0 p-3';
        container.style.zIndex = '9999';
        document.body.appendChild(container);
        }

        const toastId = 'toast-' + Date.now();
        const bgClass = type === 'danger' ? 'bg-danger' :
        type === 'warning' ? 'bg-warning' :
        type === 'success' ? 'bg-success' : 'bg-info';
        const textClass = type === 'warning' ? 'text-dark' : 'text-white';

        const toastHtml = `
        <div id="${toastId}" class="toast show ${bgClass} ${textClass} mb-2" role="alert" style="min-width: 300px;">
        <div class="toast-header ${bgClass} ${textClass}">
        <strong class="me-auto">${title}</strong>
        <small>${new Date().toLocaleTimeString()}</small>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">
        ${message}
        ${link ? `<a href="${link}" class="btn btn-sm btn-light mt-2 w-100">Görüntüle</a>` : ''}
        </div>
        </div>
        `;
        
        document.getElementById('toast-container').insertAdjacentHTML('beforeend', toastHtml);

        // 10 saniye sonra otomatik kaldır
        setTimeout(() => {
        const toast = document.getElementById(toastId);
        if (toast) toast.remove();
        }, 10000);
        }

        // Bildirim sesi (isteğe bağlı)
        function playNotificationSound() {
        const audio = new Audio('/sounds/notification.mp3');
        audio.play().catch(e => console.log('Ses çalınamadı:', e));
        }
    </script>
</body>
</html>